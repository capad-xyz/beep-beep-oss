{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dooper",
  "version": "0.0.0",
  "identifier": "io.capad.beepbeep",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Dooper",
        "width": 1280,
        "height": 800,
        "minWidth": 760,
        "minHeight": 560,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
