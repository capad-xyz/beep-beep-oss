# ─────────────────────────────────────────────────────────────────────────────
# beep-beep-oss — Phase 0 environment
#
# Copy this file to ".env" (in the same infra/ directory) and fill it in:
#     cp .env.example .env
#
# .env is gitignored and must NEVER be committed — it holds secrets.
# ─────────────────────────────────────────────────────────────────────────────

# The public name of your homeserver. This becomes part of every user ID
# (@you:SERVER_NAME) and CANNOT be changed later without breaking everything.
#
#   LOCAL path  → use:  localhost
#   PUBLIC path → use your real domain, e.g.  beep.example.com
#                 (a free DuckDNS subdomain like  yourname.duckdns.org  works)
SERVER_NAME=localhost

# Postgres credentials. The user can stay "beep"; pick a strong password.
# Generate one with:  openssl rand -hex 24
POSTGRES_USER=beep
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# Where Synapse's client API (port 8008) is bound on the HOST.
#   LOCAL path  → 127.0.0.1:8008   (default; not exposed to the internet)
#   PUBLIC path → leave as default; Caddy fronts it with TLS on 443
SYNAPSE_BIND=127.0.0.1:8008
